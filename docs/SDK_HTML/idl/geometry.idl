        [helpstring("Computes the unit-vector tangent at each of the points, given an array of parameter values on the curve."), helpcontext(0x00004e44)]
        HRESULT _stdcall GetTangent(
                        [in] long NumParams, 
                        [in, out] SAFEARRAY(double)* Params, 
                        [in, out] SAFEARRAY(double)* Tangents);
        [propget, helpstring("Returns the number of times the referenced object has been modified."), helpcontext(0x00004e2f)]
        HRESULT _stdcall UpdatesCounter([out, retval] long* Counter);
        [propget, helpstring("Returns the Parasolid ID of the Edge."), helpcontext(0x0098967f)]
        HRESULT _stdcall ID([out, retval] int* EdgeID);
        [propget, helpstring("Returns the Tag of the Edge."), helpcontext(0x0098967f)]
        HRESULT _stdcall Tag([out, retval] int* EdgeTag);
        [propget, helpstring("Returns the Body of the Edge."), helpcontext(0x0098967f)]
