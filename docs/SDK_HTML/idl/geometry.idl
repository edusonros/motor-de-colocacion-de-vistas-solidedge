        HRESULT _stdcall GetEdgeUses(
                        [out] long* NumEdgeUses, 
                        [in, out] SAFEARRAY(IDispatch*)* EdgeUses);
        [propget, helpstring("Returns the Vertex object that occurs at the end of the referenced Edge."), helpcontext(0x00004e66)]
        HRESULT _stdcall EndVertex([out, retval] IDispatch** EndVertex);
