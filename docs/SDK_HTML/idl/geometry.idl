                        [in, out] SAFEARRAY(double)* MaxDeviations, 
                        [in, out] SAFEARRAY(double)* Params, 
                        [in, out] SAFEARRAY(long)* Flags);
        [helpstring("Returns a parameter at a given length, measured along the curve, starting from a given parameter."), helpcontext(0x00004e7a)]
        HRESULT _stdcall GetParamAtLength(
                        [in] double FromParam, 
