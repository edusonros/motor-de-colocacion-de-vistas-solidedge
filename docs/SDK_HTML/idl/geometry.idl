                        [out] long* StrokeCount, 
                        [in, out] SAFEARRAY(double)* Points, 
                        [in, out] SAFEARRAY(double)* Params);
        [propget, helpstring("Returns a member of the GNTTypePropertyConstants set to indicate the type of the referenced object."), helpcontext(0x00002722)]
        HRESULT _stdcall Type([out, retval] GNTTypePropertyConstants* Type);
        [propget, helpstring("Returns the continuity of the referenced object."), helpcontext(0x00004e71)]
        HRESULT _stdcall Continuity([out, retval] long* Continuity);
        [helpstring("Computes the curvature of the referenced edge at a specified point."), helpcontext(0x00004e72)]
        HRESULT _stdcall GetCurvature(
                        [in] long NumParams, 
                        [in, out] SAFEARRAY(double)* Params, 
                        [in, out] SAFEARRAY(double)* Directions, 
                        [in, out] SAFEARRAY(double)* Curvatures);
        [helpstring("Evaluates the derivatives of the referenced curve at the points given by an array of parameters on the curve."), helpcontext(0x00004e3e)]
        HRESULT _stdcall GetDerivatives(
                        [in] long NumParams, 
