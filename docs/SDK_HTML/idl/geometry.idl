            void GetPointAtParam(
                            [in] long NumParams, 
                            [in, out] SAFEARRAY(double)* Params, 
                            [in, out] SAFEARRAY(double)* Points);
            [id(0x00000112), helpstring("Computes the unit-vector tangent at each of the points, given an array of parameter values on the curve."), helpcontext(0x00004e44)]
            void GetTangent(
                            [in] long NumParams, 
                            [in, out] SAFEARRAY(double)* Params, 
                            [in, out] SAFEARRAY(double)* Tangents);
