                        [in, out] SAFEARRAY(double)* ThirdDerv);
        [propget, helpstring("Specifies the geometry form of the referenced object."), helpcontext(0x00004e2b)]
        HRESULT _stdcall GeometryForm([out, retval] long* GeometryForm);
        [helpstring("Returns the minimum and maximum points of the range for the referenced object."), helpcontext(0x00004e28)]
        HRESULT _stdcall GetRange(
                        [in, out] SAFEARRAY(double)* MinRangePoint, 
                        [in, out] SAFEARRAY(double)* MaxRangePoint);
        [helpstring("Returns the exact range for the referenced object."), helpcontext(0x0000d6ef)]
        HRESULT _stdcall GetExactRange(
                        [in, out] SAFEARRAY(double)* MinRangePoint, 
                        [in, out] SAFEARRAY(double)* MaxRangePoint);
        [helpstring("Returns the start and end points of the referenced object."), helpcontext(0x00004e40)]
        HRESULT _stdcall GetEndPoints(
                        [in, out] SAFEARRAY(double)* StartPoint, 
                        [in, out] SAFEARRAY(double)* EndPoint);
        [helpstring("Returns the length, measured along the curve, from one given parameter to another."), helpcontext(0x00004e77)]
        HRESULT _stdcall GetLengthAtParam(
                        [in] double FromParam, 
