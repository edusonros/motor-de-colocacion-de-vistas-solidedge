                        [out] double* Param);
        [helpstring("Returns the parametric extents of the curve."), helpcontext(0x00004e42)]
        HRESULT _stdcall GetParamExtents(
                        [out] double* MinParam, 
                        [out] double* MaxParam);
        [helpstring("Computes the corresponding model space points in the local coordinate system, given an array of parameters on the curve."), helpcontext(0x00004e43)]
        HRESULT _stdcall GetPointAtParam(
                        [in] long NumParams, 
