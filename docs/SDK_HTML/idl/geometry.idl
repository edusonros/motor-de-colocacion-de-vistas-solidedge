                        [out] long* NumFaces, 
                        [in, out] SAFEARRAY(IDispatch*)* Faces);
        [propget, helpstring("Returns a 3-D geometry object whose properties and methods can extend to the topology collection."), helpcontext(0x00004e37)]
        HRESULT _stdcall Geometry([out, retval] IDispatch** Geometry);
        [propget, helpstring("Returns a Boolean value to specify whether or not the inherent direction of the referenced object is opposed to the flow dicated by the parameterization of the underlying geometry."), helpcontext(0x00004e35)]
        HRESULT _stdcall IsParamReversed([out, retval] VARIANT_BOOL* PaGetramReversed);
        [propget, helpstring("Returns a Boolean value to specify whether or not the start and end points of the referenced object are coincident."), helpcontext(0x00004e3b)]
        HRESULT _stdcall IsClosed([out, retval] VARIANT_BOOL* Closed);
        [propget, helpstring("Returns the parent object for the referenced object."), helpcontext(0x00002713)]
        HRESULT _stdcall Parent([out, retval] IDispatch** Parent);
        [helpstring("Returns a reference key for the referenced object."), helpcontext(0x00004e6c)]
        HRESULT _stdcall GetReferenceKey(
                        [in, out] SAFEARRAY(unsigned char)* ReferenceKey, 
                        [out, optional] VARIANT* KeySize);
        [propget, helpstring("Returns the Vertex object that occurs at the start of the referenced Edge."), helpcontext(0x00004e6d)]
        HRESULT _stdcall StartVertex([out, retval] IDispatch** StartVertex);
        [propget, helpstring("Returns the number of strokes on the referenced Edge."), helpcontext(0x00004e6e)]
        HRESULT _stdcall StrokeCount(
