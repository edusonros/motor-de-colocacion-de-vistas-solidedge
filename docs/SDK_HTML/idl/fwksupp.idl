    typedef [helpstring("Text Tab Types"), helpcontext(0x00015fe9)]
    enum {
        igTextTabFlushLeft = 1,
        igTextTabFlushRight = 2,
        igTextTabFlushCentered = 3,
        igTextTabFlushDecimal = 4
    } TextTabTypeConstants;

    typedef [helpstring("Constants used with TextEdit.SetSelect"), helpcontext(0x00015fd9)]
    enum {
        seTextSelectRange = 0,
        seTextSelectWord = 1,
        seTextSelectParagraph = 2,
        seTextSelectAll = 5
    } TextSelectConstants;

    typedef [helpstring("Text Special Indent Types"), helpcontext(0x000160dc)]
    enum {
        igIndentNone = 0,
        igFirstline = 1,
        igHanging = 2
    } TextSpecialIndentTypeConstants;

    typedef [helpstring("Text Line Spacing Types"), helpcontext(0x000160da)]
    enum {
        igSingle = 0,
        igOneAndHalf = 1,
        igDouble = 2,
        igAtLeast = 3,
        igExactly = 4,
        igMultiple = 5
    } TextLineSpacingTypeConstants;

    typedef [helpstring("Text Fraction Types"), helpcontext(0x000160dd)]
    enum {
        igStacked = 1,
        igTolerance = 2,
        igSkewed = 3,
        igLinearFraction = 4
    } TextFractionTypeConstants;

    typedef [helpstring("Text Fraction Align Types"), helpcontext(0x000160de)]
    enum {
        igUpper = 1,
        igMiddle = 2,
        igLower = 3
    } TextFractionAlignConstants;

    typedef [helpstring("Text Fraction Sizes"), helpcontext(0x000160df)]
    enum {
        ig10 = 0,
        ig20 = 1,
        ig30 = 2,
        ig40 = 3,
        ig50 = 4,
        ig60 = 5,
        ig70 = 6,
        ig80 = 7,
        ig90 = 8,
        ig100 = 9
    } TextFractionSizeConstants;

    typedef [helpstring("Text Bullet Types"), helpcontext(0x000160e0)]
    enum {
        igFilledRound = 0,
        igHollowRound = 1,
        igFilledSquare = 2,
        igHollowSquare = 3,
        igStar = 4,
        igArrow = 5,
        igCheckmark = 6,
        igDash = 7
    } TextBulletTypeConstants;

    typedef [helpstring("Text Number Types"), helpcontext(0x000160e1)]
    enum {
        igPlain = 0,
        igCapitalRoman = 1,
        igSmallRoman = 2,
        igCapitalLatinAlpha = 3,
        igSmallLatinAlpha = 4
    } TextNumberTypeConstants;

    typedef [helpstring("Text Number Format"), helpcontext(0x000160e2)]
    enum {
        igNoFormat = 0,
        igPeriod = 1,
        igBracket = 2,
        igDoubleBrackets = 3
    } TextNumberFormatConstants;

    typedef [helpstring("Text Number Justification"), helpcontext(0x000160e3)]
    enum {
        igLeftJustification = 0,
        igCenterJustification = 1,
        igRightJustification = 2
    } TextNumberJustificationConstants;

    typedef [helpstring("Border Type"), helpcontext(0x00015fea)]
    enum {
        igTextBorderNone = 0,
        igTextBorderRectangle = 1
    } TextBorderTypeConstants;

    typedef [helpstring("Text Flow Direction"), helpcontext(0x00015fec)]
    enum {
        igTextLeftToRight = 0,
        igTextRightToLeft = 1
    } TextFlowDirectionConstants;

    typedef [helpstring("Text Flow Orientation"), helpcontext(0x00015feb)]
    enum {
        igTextHorizontal = 0,
        igTextVertical = 1
    } TextFlowOrientationConstants;

    typedef [helpstring("Text Placement Types"), helpcontext(0x00015fe8)]
    enum {
        igTextBoxType = 1,
        igTextStringType = 2
    } TextPlacementTypeConstants;

    typedef [helpstring("Text Control Types"), helpcontext(0x000160db)]
    enum {
        igTextFitToContent = 0,
        igTextAdjustAspectRatio = 1,
        igTextWrap = 2
    } TextControlTypeConstants;

