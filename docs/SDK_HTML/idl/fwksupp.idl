    [
      uuid(8D73E634-9DEB-4E69-BFC4-5FEDC46E78CE),
      helpstring("Stores the data required to create a dimension.  Use with AddDimension() method.  This is the only way to create PMI dimensions."),
      helpcontext(0x0098967f)
    ]
    dispinterface DimInitData {
        properties:
        methods:
            [id(0x60000000), restricted]
            void QueryInterface(
                            [in] GUID* riid, 
                            [out] void** ppvObj);
            [id(0x60000001), restricted]
            unsigned long AddRef();
            [id(0x60000002), restricted]
            unsigned long Release();
            [id(0x00000001), propget, helpstring("Returns the active application object."), helpcontext(0x0098967f)]
            Application* Application();
            [id(0x00000003), helpstring("Sets the type of dimension."), helpcontext(0x0098967f)]
            void SetType([in] DimTypeConstants DimensionType);
            [id(0x00000004), helpstring("Sets the axis mode.  Not used when creating a Chamfer Dimension, use SetChamferAxisMode instead."), helpcontext(0x0098967f)]
            void SetAxisMode([in] DimAxisModeConstants AxisMode);
            [id(0x0000000f), helpstring("Sets the chamfer axis mode.  Use when creating a Chamfer Dimension."), helpcontext(0x0098967f)]
            void SetChamferAxisMode([in] DimChamferModeConstants chamferAxisMode);
            [id(0x0000000a), helpstring("Sets the number of parents with which the dimension will be created."), helpcontext(0x0098967f)]
            void SetNumberOfParents([in] int numberOfParents);
            [id(0x00000002), helpstring("Sets parent data. Object must be 2d geometry, reference, or edge or vertex (for PMI). For coordinate dimensions (except the origin), the first parent must be a dimension object that belongs to the group. UseVirtualVertex is used for PMI."), helpcontext(0x0098967f)]
            void SetParentByIndex(
                            [in] int Index, 
                            [in] IDispatch* Object, 
                            [in] VARIANT_BOOL IsKeyPoint, 
                            [in] VARIANT_BOOL IsIntersection, 
                            [in] VARIANT_BOOL IsTangentPoint, 
                            [in] VARIANT_BOOL UseVirtualVertex, 
                            [in] double x, 
                            [in] double y, 
                            [in] double z);
            [id(0x00000005), helpstring("Clears the parent data and sets the number of parents to zero. Use between calls to CreateDimension."), helpcontext(0x0098967f)]
            void ClearParents();
            [id(0x00000010), helpstring("Resets all the data in this DimInitData object."), helpcontext(0x0098967f)]
            void ClearCreationData();
            [id(0x00000006), helpstring("Sets the dimension axis and will be used by explicit axis dimensions. The axis mode can be set by using the method SetAxisMode."), helpcontext(0x0098967f)]
            void SetAxis([in] IDispatch* Axis);
            [id(0x00000007), helpstring("Clears the dimension axis."), helpcontext(0x0098967f)]
            void ClearAxis();
            [id(0x00000008), helpstring("Sets the plane in which the dimension will be created.  This is used only for creating PMI dimensions. (XY plane is the default plane)"), helpcontext(0x0098967f)]
            void SetPlane([in] IDispatch* Plane);
            [id(0x00000009), helpstring("Clears the dimension plane."), helpcontext(0x0098967f)]
            void ClearPlane();
            [id(0x0000000b), helpstring("Set TRUE to create an angular dimension that reads counterclockwise. This is specific to angular coordinate dimensions."), helpcontext(0x0098967f)]
            void SetAngularCoordinateCounterClockwise([in] VARIANT_BOOL bCounterClockWise);
            [id(0x0000000c), helpstring("Set TRUE to specify whether to use SetDimPosition value to  position the coordinate and angular coordinate dimensions when created.  Set FALSE to use default position."), helpcontext(0x0098967f)]
            void SetDimPositionMode([in] VARIANT_BOOL bPositionDim);
            [id(0x0000000d), helpstring("Sets the position of the dimension. This works in conjunction with SetDimPositionMode."), helpcontext(0x0098967f)]
            void SetDimPosition(
                            [in] double x, 
                            [in] double y, 
                            [in] double z);
            [id(0x0000000e), helpstring("Set TRUE if creating an angular coordinate origin dimension."), helpcontext(0x0098967f)]
            void SetAngularCoordOrigin([in] VARIANT_BOOL bIsOriginDim);
    };

